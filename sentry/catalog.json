{
  "name": "Sentry",
  "description": "Search errors, investigate issues, and access Seer AI root-cause analysis from Sentry.",
  "category": "monitoring",
  "tags": ["errors", "debugging", "observability", "crash-reporting"],
  "iconUrl": "https://raw.githubusercontent.com/overcut-ai/overcut-mcp-catalog/main/sentry/icon.svg",
  "websiteUrl": "https://github.com/getsentry/sentry-mcp",
  "priority": 10,
  "serverConfig": {
    "command": "npx",
    "args": ["-y", "@sentry/mcp-server@latest"],
    "env": {
      "SENTRY_ACCESS_TOKEN": "${SENTRY_ACCESS_TOKEN}"
    }
  },
  "requiredSecrets": [
    {
      "envVar": "SENTRY_ACCESS_TOKEN",
      "displayName": "Sentry Access Token",
      "description": "Create an Internal Integration token at Settings > Custom Integrations with org:read, project:read, project:write, team:read, team:write, event:write scopes.",
      "helpUrl": "https://docs.sentry.io/api/guides/create-auth-token/"
    }
  ],
  "recommendedTools": [
    "search_events",
    "get_issue_details",
    "find_projects",
    "find_organizations"
  ],
  "allTools": [
    "search_events",
    "search_issues",
    "search_issue_events",
    "get_issue_details",
    "get_issue_tag_values",
    "find_projects",
    "find_organizations",
    "find_releases",
    "find_teams",
    "find_dsns",
    "list_events",
    "list_issues",
    "list_issue_events",
    "create_project",
    "create_team",
    "create_dsn",
    "update_issue",
    "update_project",
    "analyze_issue_with_seer",
    "get_event_attachment",
    "get_trace_details",
    "get_sentry_resource",
    "get_doc",
    "search_docs",
    "use_sentry",
    "whoami"
  ]
}
