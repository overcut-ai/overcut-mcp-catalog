{
  "name": "Splunk",
  "description": "Execute SPL queries, search logs, list indexes, and manage saved searches in Splunk Enterprise and Cloud.",
  "category": "monitoring",
  "tags": ["logs", "siem", "search", "analytics", "security", "observability"],
  "iconUrl": "https://raw.githubusercontent.com/overcut-ai/overcut-mcp-catalog/main/splunk/icon.svg",
  "websiteUrl": "https://github.com/livehybrid/splunk-mcp",
  "priority": 14,
  "serverConfig": {
    "command": "uvx",
    "args": ["--from", "git+https://github.com/livehybrid/splunk-mcp.git", "splunk-mcp", "stdio"],
    "env": {
      "SPLUNK_HOST": "${SPLUNK_HOST}",
      "SPLUNK_TOKEN": "${SPLUNK_TOKEN}"
    }
  },
  "requiredSecrets": [
    {
      "envVar": "SPLUNK_HOST",
      "displayName": "Splunk Host",
      "description": "Your Splunk host address (e.g., splunk.example.com)."
    },
    {
      "envVar": "SPLUNK_TOKEN",
      "displayName": "Splunk Auth Token",
      "description": "A Splunk authentication token. Alternatively use SPLUNK_USERNAME and SPLUNK_PASSWORD for basic auth.",
      "helpUrl": "https://docs.splunk.com/Documentation/Splunk/latest/Security/Setupauthenticationtokens"
    }
  ],
  "recommendedTools": [
    "search_splunk",
    "list_indexes",
    "list_saved_searches",
    "health_check"
  ],
  "allTools": [
    "search_splunk",
    "list_indexes",
    "get_index_info",
    "indexes_and_sourcetypes",
    "list_saved_searches",
    "health_check",
    "ping",
    "current_user",
    "list_users",
    "list_kvstore_collections",
    "create_kvstore_collection",
    "delete_kvstore_collection"
  ]
}
