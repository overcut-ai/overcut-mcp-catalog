{
  "name": "Notion",
  "description": "Search, read, and edit Notion pages, databases, and blocks. Access your team's knowledge base directly.",
  "category": "documentation",
  "tags": ["knowledge-base", "wiki", "documents", "databases", "notes"],
  "iconUrl": "https://raw.githubusercontent.com/overcut-ai/overcut-mcp-catalog/main/notion/icon.svg",
  "websiteUrl": "https://github.com/makenotion/notion-mcp-server",
  "priority": 12,
  "serverConfig": {
    "command": "npx",
    "args": ["-y", "@notionhq/notion-mcp-server"],
    "env": {
      "NOTION_TOKEN": "${NOTION_TOKEN}"
    }
  },
  "requiredSecrets": [
    {
      "envVar": "NOTION_TOKEN",
      "displayName": "Notion Integration Token",
      "description": "Create an internal integration at notion.so/my-integrations with the content capabilities you need, then share relevant pages with the integration.",
      "helpUrl": "https://developers.notion.com/docs/create-a-notion-integration"
    }
  ],
  "recommendedTools": [
    "API-post-search",
    "API-retrieve-a-page",
    "API-get-block-children",
    "API-query-data-source",
    "API-retrieve-a-database"
  ],
  "allTools": [
    "API-post-search",
    "API-retrieve-a-page",
    "API-get-block-children",
    "API-patch-block-children",
    "API-post-page",
    "API-patch-page",
    "API-retrieve-a-page-property",
    "API-retrieve-a-block",
    "API-update-a-block",
    "API-delete-a-block",
    "API-retrieve-a-database",
    "API-query-data-source",
    "API-retrieve-a-data-source",
    "API-update-a-data-source",
    "API-create-a-data-source",
    "API-list-data-source-templates",
    "API-move-page",
    "API-create-a-comment",
    "API-retrieve-a-comment",
    "API-get-user",
    "API-get-users",
    "API-get-self"
  ]
}
