{
  "name": "Brave Search",
  "description": "Search the web, images, videos, and news using the Brave Search API with AI-powered summaries.",
  "category": "data",
  "tags": ["search", "web", "browse", "research"],
  "iconUrl": "https://raw.githubusercontent.com/overcut-ai/overcut-mcp-catalog/main/brave-search/icon.svg",
  "websiteUrl": "https://github.com/brave/brave-search-mcp-server",
  "priority": 30,
  "serverConfig": {
    "command": "npx",
    "args": ["-y", "@brave/brave-search-mcp-server"],
    "env": {
      "BRAVE_API_KEY": "${BRAVE_API_KEY}"
    }
  },
  "requiredSecrets": [
    {
      "envVar": "BRAVE_API_KEY",
      "displayName": "Brave Search API Key",
      "description": "Get a free API key from the Brave Search API dashboard.",
      "helpUrl": "https://brave.com/search/api/"
    }
  ],
  "recommendedTools": [
    "brave_web_search",
    "brave_local_search",
    "brave_news_search"
  ],
  "allTools": [
    "brave_web_search",
    "brave_local_search",
    "brave_image_search",
    "brave_video_search",
    "brave_news_search",
    "brave_summarizer"
  ]
}
