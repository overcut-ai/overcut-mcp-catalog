{
  "name": "Brave Search",
  "description": "Search the web using Brave Search API with both web and local search capabilities.",
  "category": "data",
  "tags": ["search", "web", "browse", "research"],
  "iconUrl": "https://raw.githubusercontent.com/overcut-ai/overcut-mcp-catalog/main/brave-search/icon.svg",
  "websiteUrl": "https://github.com/modelcontextprotocol/servers/tree/main/src/brave-search",
  "priority": 30,
  "serverConfig": {
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-brave-search"],
    "env": {
      "BRAVE_API_KEY": "${BRAVE_API_KEY}"
    }
  },
  "requiredSecrets": [
    {
      "envVar": "BRAVE_API_KEY",
      "displayName": "Brave Search API Key",
      "description": "Get a free API key from the Brave Search API dashboard.",
      "helpUrl": "https://brave.com/search/api/"
    }
  ],
  "recommendedTools": [
    "brave_web_search",
    "brave_local_search"
  ],
  "allTools": [
    "brave_web_search",
    "brave_local_search"
  ]
}
