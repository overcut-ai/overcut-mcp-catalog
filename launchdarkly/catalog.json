{
  "name": "LaunchDarkly",
  "description": "Manage feature flags, environments, and AI configs from LaunchDarkly.",
  "category": "developer-tools",
  "tags": ["feature-flags", "feature-management", "experimentation", "toggles"],
  "iconUrl": "https://raw.githubusercontent.com/overcut-ai/overcut-mcp-catalog/main/launchdarkly/icon.svg",
  "websiteUrl": "https://launchdarkly.com/docs/home/getting-started/mcp",
  "priority": 18,
  "serverConfig": {
    "command": "npx",
    "args": ["-y", "--package", "@launchdarkly/mcp-server", "--", "mcp", "start", "--api-key", "${LAUNCHDARKLY_ACCESS_TOKEN}"],
    "env": {}
  },
  "requiredSecrets": [
    {
      "envVar": "LAUNCHDARKLY_ACCESS_TOKEN",
      "displayName": "LaunchDarkly Access Token",
      "description": "API access token from LaunchDarkly. Found at Settings > Authorization. Format: api-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx.",
      "helpUrl": "https://docs.launchdarkly.com/home/account/api"
    }
  ],
  "recommendedTools": [
    "list-feature-flags",
    "get-feature-flag",
    "create-feature-flag",
    "update-feature-flag",
    "get-flag-status-across-environments",
    "get-environments"
  ],
  "allTools": [
    "list-feature-flags",
    "create-feature-flag",
    "get-feature-flag",
    "update-feature-flag",
    "delete-feature-flag",
    "get-flag-status-across-environments",
    "get-environments",
    "get-code-references",
    "list-ai-configs",
    "create-ai-config",
    "get-ai-config",
    "update-ai-config",
    "delete-ai-config",
    "get-ai-config-targeting",
    "update-ai-config-targeting",
    "create-ai-config-variation",
    "delete-ai-config-variation",
    "get-ai-config-variation",
    "update-ai-config-variation"
  ]
}
